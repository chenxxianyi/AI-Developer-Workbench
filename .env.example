# ─── Docker Compose 环境变量 ───
# 复制此文件为 .env 后运行: docker compose up -d

# MySQL 配置
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=ai_workbench
MYSQL_USER=workbench
MYSQL_PASSWORD=change_me_user

# AI 配置 — 必须连接真实 AI 服务
# 后端启动时会校验此项，未配置将直接报错。
AI_API_KEY=
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4.1
# AI_VISION_MODEL=gpt-4.1

# CORS — 前端访问地址
CORS_ALLOW_ORIGINS=http://localhost:5173
